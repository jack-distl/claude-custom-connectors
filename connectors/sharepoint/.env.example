# Port (Railway sets this automatically)
PORT=3000

# Public URL of this connector (REQUIRED for OAuth callbacks)
# After deploying to Railway, generate a domain and set this to the full URL
# e.g., https://sharepoint-connector-production-xxxx.up.railway.app
SERVER_URL=

# Azure AD / Microsoft Entra ID credentials
# Get these from Azure Portal → App registrations → your app
CLIENT_ID=
CLIENT_SECRET=

# Your Azure AD tenant ID (found in Azure Portal → Azure Active Directory → Overview)
AZURE_TENANT_ID=
