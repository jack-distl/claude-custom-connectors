# Port (Railway sets this automatically)
PORT=3000

# Public URL of this connector (REQUIRED for OAuth callbacks)
# After deploying to Railway, generate a domain and set this to the full URL
# e.g., https://my-connector-production-xxxx.up.railway.app
SERVER_URL=

# OAuth credentials for this connector's third-party service
# Get these from the third-party provider's developer portal
CLIENT_ID=
CLIENT_SECRET=
